{
  "name": "mafia-game",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "pnpx @opennextjs/cloudflare build && sed -i \"/DOQueueHandler\\|DOShardedTagCache\\|BucketCachePurge/d\" .open-next/worker.js",
    "deploy": "pnpm build:cf && pnpx wrangler deploy",
    "preview": "pnpm build:cf && pnpx wrangler dev",
    "start": "next start",
    "lint": "eslint src/",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "db:migrate:staging": "pnpx wrangler d1 migrations apply mafia-game-staging-db --remote --env staging",
    "db:migrate:prod": "pnpx wrangler d1 migrations apply mafia-game-db --remote",
    "db:migrate:local": "pnpx wrangler d1 migrations apply mafia-game-db --local"
  },
  "dependencies": {
    "nanoid": "^5.0.0",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "license": "MIT"
}
